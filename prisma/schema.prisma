generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  BOOKER
  DISTRIBUTOR
  RETAILER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  outlets   Outlet[]
  products  Product[]
  orders    Order[]
  invoices  Invoice[]
  users     User[]
}

model Outlet {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  address          String?
  creditLimitPaisa Int      @default(0)
  isDeleted        Boolean  @default(false)
  deletedAt        DateTime?
  createdAt        DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  users    User[]
  orders   Order[]
  invoices Invoice[]

  @@index([tenantId])
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  outletId  String?
  role      Role
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  outlet Outlet? @relation(fields: [outletId], references: [id])

  @@index([tenantId, outletId])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  unit        String   @default("ctn")
  pricePaisa  Int
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  stockLedger  StockLedger[]
  orderItems   OrderItem[]
  invoiceItems InvoiceItem[]

  @@index([tenantId])
}

model StockLedger {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  quantity  Int
  reason    String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId, productId])
}

model Order {
  id         String      @id @default(cuid())
  orderNo    String      @unique @default(cuid())
  tenantId   String
  outletId   String
  status     OrderStatus @default(PENDING)
  totalPaisa Int
  notes      String?
  deliveryDate DateTime?
  isDeleted  Boolean     @default(false)
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())

  tenant  Tenant      @relation(fields: [tenantId], references: [id])
  outlet  Outlet      @relation(fields: [outletId], references: [id])
  items   OrderItem[]
  invoice Invoice?

  @@index([tenantId, outletId])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  productId  String
  name       String
  quantity   Int
  pricePaisa Int

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Invoice {
  id           String        @id @default(cuid())
  invoiceNo    String        @unique @default(cuid())
  tenantId     String
  outletId     String
  orderId      String?       @unique
  totalPaisa   Int
  paidPaisa    Int           @default(0)
  status       InvoiceStatus @default(PENDING)
  dueDate      DateTime
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  outlet   Outlet          @relation(fields: [outletId], references: [id])
  order    Order?          @relation(fields: [orderId], references: [id])
  items    InvoiceItem[]
  payments InvoicePayment[]

  @@index([tenantId, outletId])
}

model InvoiceItem {
  id         String @id @default(cuid())
  invoiceId  String
  productId  String
  name       String
  quantity   Int
  pricePaisa Int

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([invoiceId])
}

model InvoicePayment {
  id         String   @id @default(cuid())
  invoiceId  String
  amountPaisa Int
  method     String
  reference  String?
  createdAt  DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}